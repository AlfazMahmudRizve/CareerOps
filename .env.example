# ----------------------------------------------------------------------------
# Environment Configuration Template
#
# Copy this file to `.env.local` and fill in your values.
# `.env.local` is gitignored and never committed.
#
#   cp .env.example .env.local
#
# All values below are placeholders only — do NOT commit real secrets.
# ----------------------------------------------------------------------------

# NVIDIA NIM (resume analyzer)
# Used by the semantic resume analyzer when ANALYZER_BACKEND=nim.
# Get a free key at https://build.nvidia.com
# NOTE: free-tier model names change often. If you see "403 Authorization failed"
# even with a valid key, the model may be retired — check build.nvidia.com for
# the current "llama-3.x-70b" identifier and update NVIDIA_NIM_MODEL.
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_NIM_API_KEY=
NVIDIA_NIM_MODEL=meta/llama-3.3-70b-instruct

# Analyzer backend selector:
#   'legacy' → rule-based analyzer (default, no API key required)
#   'nim'    → NVIDIA NIM-powered semantic analyzer (requires API key)
# Falls back to 'legacy' automatically if a NIM call fails.
ANALYZER_BACKEND=legacy

# Application port
# Default: 3000 (used by most Node/Next.js dev servers)
# Change this if port 3000 is already taken on your machine.
# To check whether a port is busy:
#   Windows:    netstat -ano | findstr :3000
#   macOS/Linux: lsof -i :3000   (or:  ss -tlnp | grep 3000)
# If the port is in use, either stop the conflicting process or set PORT to
# a free port (e.g. 3001, 3002) below.
PORT=3001

# Analyzer diagnostics
# When '1', prints the actual NIM failure reason on stderr (status, message).
# Recommended: '1' in development, '0' in production.
ANALYZER_DEBUG=1

# Hard cap on how long the NIM call can run before falling back to legacy.
# Default in code: 15000. Lower this in dev for faster fallback feedback.
NIM_TIMEOUT_MS=8000